{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "dom"],
    "types": ["cypress", "node"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "baseUrl": "..",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["**/*.ts", "../cypress.config.ts"]
}
